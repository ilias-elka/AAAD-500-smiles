// ── STATE ──
let playerName = '';
let score = 0;
let currentQ = 0;
let timerIv = null;
let timeLeft = 20;
let answered = false;
let sbUnsubscribe = null;

function show(id) {
  ['start','quiz','end','scoreboard'].forEach(s => {
    document.getElementById(s).classList.toggle('on', s === id);
  });
}

window.show = show;

// ── START ──
window.startQuiz = function() {
  const n = document.getElementById('nameInput').value.trim();
  if (!n) { document.getElementById('nameInput').focus(); return; }
  playerName = n; score = 0; currentQ = 0;
  document.getElementById('qPlayerName').textContent = playerName;
  show('quiz');
  loadQ(0);
};

// ── LOAD QUESTION ──
function loadQ(idx) {
  answered = false;
  clearInterval(timerIv);
  const q = Q[idx];
  const total = Q.length;

  document.getElementById('qProgFill').style.width = ((idx/total)*100)+'%';
  document.getElementById('qProgLbl').textContent = `Vraag ${idx+1} van ${total}`;

  const tag = document.getElementById('qCatTag');
  tag.textContent = q.catL; tag.className = 'cat-tag cat-'+q.cat;
  document.getElementById('qText').textContent = q.q;

  const grid = document.getElementById('qAnsGrid');
  grid.innerHTML = '';
  q.a.forEach((a,i) => {
    const btn = document.createElement('button');
    btn.className='ans-btn'; btn.id='ab_'+i;
    btn.innerHTML=`<span style="font-size:1.1rem;flex-shrink:0">${SHAPES[i]}</span>${a}`;
    btn.onclick=()=>answer(i);
    grid.appendChild(btn);
  });

  document.getElementById('qFeedback').style.display='none';
  document.getElementById('qNextBtn').style.display='none';
  document.getElementById('qScore').textContent=score;

  timeLeft=20; updateTimer();
  timerIv=setInterval(()=>{
    timeLeft--; updateTimer();
    if(timeLeft<=0){clearInterval(timerIv);if(!answered)timeout();}
  },1000);
}

function updateTimer(){
  document.getElementById('qTimerNum').textContent=timeLeft;
  document.getElementById('qTimerPill').className=timeLeft<=5?'timer-pill urgent':'timer-pill';
}

function answer(idx){
  if(answered)return;
  answered=true; clearInterval(timerIv);
  const q=Q[currentQ];
  for(let i=0;i<4;i++){
    const b=document.getElementById('ab_'+i); if(!b)continue;
    b.disabled=true;
    if(i===q.c)b.classList.add('correct');
    else if(i===idx)b.classList.add('wrong');
    else b.style.opacity='.4';
  }
  const fb=document.getElementById('qFeedback');
  if(idx===q.c){
    const pts=Math.max(100,timeLeft*50); score+=pts;
    document.getElementById('qScore').textContent=score;
    fb.className='feedback ok';
    document.getElementById('qFbTitle').className='fb-title ok';
    document.getElementById('qFbTitle').textContent='✅ Goed! +'+pts+' punten';
  } else {
    fb.className='feedback bad';
    document.getElementById('qFbTitle').className='fb-title bad';
    document.getElementById('qFbTitle').textContent='❌ Helaas, dat klopt niet';
  }
  document.getElementById('qFbBody').textContent='💡 '+q.fact;
  fb.style.display='block';
  document.getElementById('qNextBtn').style.display='inline-block';
}

function timeout(){
  if(answered)return; answered=true;
  const q=Q[currentQ];
  for(let i=0;i<4;i++){const b=document.getElementById('ab_'+i);if(b){b.disabled=true;b.style.opacity='.4';}}
  const cb=document.getElementById('ab_'+q.c);if(cb){cb.style.opacity='1';cb.classList.add('correct');}
  const fb=document.getElementById('qFeedback');
  fb.className='feedback bad';
  document.getElementById('qFbTitle').className='fb-title bad';
  document.getElementById('qFbTitle').textContent='⏱️ Te laat! Geen punten';
  document.getElementById('qFbBody').textContent='💡 '+q.fact;
  fb.style.display='block';
  document.getElementById('qNextBtn').style.display='inline-block';
}

window.nextQ = function(){
  currentQ++;
  if(currentQ>=Q.length) showEnd();
  else loadQ(currentQ);
};

// ── END + FIREBASE SAVE ──
function showEnd(){
  show('end');
  const pct=Math.min(100,Math.round((score/(Q.length*1000))*100));
  let trophy,title,stars,msg;
  if(pct>=85){trophy='🏆';title='Fantastisch!';stars='⭐⭐⭐';msg='Wauw, je weet echt veel over sociaal media! Deel je kennis met je vrienden.';}
  else if(pct>=55){trophy='🥈';title='Goed bezig!';stars='⭐⭐';msg='Netjes! Er is nog wat te leren, maar je snapt al goed hoe sociaal media werkt.';}
  else{trophy='📱';title='Blijf leren!';stars='⭐';msg='Sociaal media heeft meer invloed dan je denkt. Speel nog een keer en leer er alles over!';}

  document.getElementById('endTrophy').textContent=trophy;
  document.getElementById('endTitle').textContent=title;
  document.getElementById('endName').textContent=playerName+', jij hebt gescoord:';
  document.getElementById('endPts').textContent=score+' punten';
  document.getElementById('endStars').textContent=stars;
  document.getElementById('endMsg').textContent=msg;
  setTimeout(()=>{document.getElementById('endBar').style.width=pct+'%';},300);

  // Save to Firebase
  const badge=document.getElementById('savingBadge');
  badge.textContent='📤 Score opslaan…';
  const scoresRef=ref(db,'scores');
  push(scoresRef,{ name:playerName, score, timestamp: Date.now() })
    .then(()=>{ badge.textContent='✅ Score opgeslagen!'; })
    .catch(()=>{ badge.textContent='⚠️ Opslaan mislukt'; });
}

// ── SCOREBOARD ──
window.showScoreboard = function(){
  show('scoreboard');
  loadScoreboard();
};

window.loadScoreboard = function(){
  document.getElementById('sbList').innerHTML='<div class="sb-loading">Scores laden…</div>';
  const scoresRef=ref(db,'scores');
  // One-time read
  onValue(scoresRef,(snapshot)=>{
    const data=snapshot.val();
    if(!data){
      document.getElementById('sbList').innerHTML='<div class="sb-loading">Nog geen scores.<br>Speel de quiz als eerste! 🎯</div>';
      return;
    }
    const entries=Object.values(data)
      .filter(e=>e.name&&e.score!=null)
      .sort((a,b)=>b.score-a.score)
      .slice(0,25);

    const medals=['🥇','🥈','🥉'];
    document.getElementById('sbList').innerHTML=entries.map((e,i)=>`
      <div class="sb-row" style="animation-delay:${i*.06}s">
        <span class="sb-rank">${i+1}</span>
        <span class="sb-medal">${medals[i]||''}</span>
        <span class="sb-name">${e.name}${e.name===playerName?'<span class="sb-you">jij</span>':''}</span>
        <span class="sb-pts">${e.score} pts</span>
      </div>`).join('');
  },{onlyOnce:true});
};

window.restart=function(){ score=0; currentQ=0; show('start'); };
</script>
